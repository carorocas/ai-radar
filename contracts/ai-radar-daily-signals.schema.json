{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-radar.local/contracts/ai-radar-daily-signals.schema.json",
  "title": "AI Radar Daily Signals",
  "type": "object",
  "required": ["contract_version", "date", "query", "signals"],
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "source",
          "evidence",
          "impact",
          "action",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "object",
            "required": ["name", "url", "published_at"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "published_at": {
                "type": "string"
              }
            }
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "vigilar",
              "probar_pronto",
              "esperar_para_probar",
              "vigilar_infraestructura",
              "riesgo_alto"
            ]
          }
        }
      }
    }
  }
}
